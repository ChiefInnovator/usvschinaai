# aiolympics environment variables — copy to .env (gitignored) for local dev.
# In CI these are provided via GitHub Actions secrets on the workflow step.

# OpenAI API key for the AI gap-filling pass (see docs/ai_gap_filling.md §9).
# Required for gap-filling; without it the pass is silently skipped.
OPENAI_API_KEY=sk-proj-...

# Optional override for the gap-fill model. Defaults to the first available
# entry in DEFAULT_MODEL_CHAIN (gpt-5.4 → gpt-5.4-pro → gpt-5.3).
# The selected model MUST support the web_search tool.
# AI_GAP_FILL_MODEL=gpt-5.4
